{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "small_model": "github-copilot/gpt-5-mini",
  "provider": {
    "openrouter": {
      "options": {
        "api_key": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  }
}
